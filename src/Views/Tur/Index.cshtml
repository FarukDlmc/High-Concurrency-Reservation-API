@using TravelTripProje.Models.Sınıflar
@model List<Tur>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_LayoutSon.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<head>
</head>
<body>
    <section class="hero-wrap hero-wrap-2 js-fullheight" style="background-image: url('@Url.Content("~/template1/images/bg_1.jpg")');" data-stellar-background-ratio="0.5">
        <div class="overlay"></div>
        <div class="container">
            <div class="row no-gutters slider-text js-fullheight align-items-end justify-content-center">
                <div class="col-md-9 ftco-animate pb-5 text-center">
                    <h1 class="mb-3 bread">Seyehat Rehberleri &amp;Turlar</h1>
                    <p class="breadcrumbs"><span class="mr-2"><a href="/Default/Index/">Ana Sayfa <i class="ion-ios-arrow-forward"></i></a></span> <span>Turlar</span></p>
                </div>
            </div>
        </div>
    </section>

    <section class="ftco-section">
        <div class="container">
            <div class="row d-flex">
                @foreach (var x in Model)
                {
                    <div class="col-md-4 d-flex ftco-animate">
                        <div class="blog-entry justify-content-end">
                            <a href="/Tur/TurDetay/@x.Tur_ID" class="block-20" style="background-image: url('@x.TurImage');">
                            </a>
                            <div class="text mt-3 float-right d-block">
                                <div class="d-flex align-items-center mb-4 topp">
                                    <div class="one">
                                        @*<span class="day">21</span>*@
                                    </div>
                                    <div class="two">
                                        <span class="yr" style="font-size: 20px; margin-left: -60px;">Kişi Başı: @x.Kisi_Basi_Fiyat</span>
                                        @*<span class="mos">August</span>*@
                                    </div>
                                </div>
                                <h3 class="heading"><a href="#">@x.Ad</a></h3>
                                <p>Rota: @x.Rota</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
            <div class="row mt-5">
                <div class="col text-center">
                    <div class="block-27">
                        <ul>
                            <li><a href="#">&lt;</a></li>
                            <li class="active"><span>1</span></li>
                            <li><a href="#">2</a></li>
                            <li><a href="#">3</a></li>
                            <li><a href="#">4</a></li>
                            <li><a href="#">5</a></li>
                            <li><a href="#">&gt;</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- loader -->
    <div id="ftco-loader" class="show fullscreen"><svg class="circular" width="48px" height="48px"><circle class="path-bg" cx="24" cy="24" r="22" fill="none" stroke-width="4" stroke="#eeeeee" /><circle class="path" cx="24" cy="24" r="22" fill="none" stroke-width="4" stroke-miterlimit="10" stroke="#F96D00" /></svg></div>


    <script src="~/template1/js/jquery.min.js"></script>
    <script src="~/template1/js/jquery-migrate-3.0.1.min.js"></script>
    <script src="~/template1/js/popper.min.js"></script>
    <script src="~/template1/js/bootstrap.min.js"></script>
    <script src="~/template1/js/jquery.easing.1.3.js"></script>
    <script src="~/template1/js/jquery.waypoints.min.js"></script>
    <script src="~/template1/js/jquery.stellar.min.js"></script>
    <script src="~/template1/js/owl.carousel.min.js"></script>
    <script src="~/template1/js/jquery.magnific-popup.min.js"></script>
    <script src="~/template1/js/aos.js"></script>
    <script src="~/template1/js/jquery.animateNumber.min.js"></script>
    <script src="~/template1/js/bootstrap-datepicker.js"></script>
    <script src="~/template1/js/scrollax.min.js"></script>
    <script src="~/template1/js/google-map.js"></script>
    <script src="~/template1/js/main.js"></script>

</body>
</html>

