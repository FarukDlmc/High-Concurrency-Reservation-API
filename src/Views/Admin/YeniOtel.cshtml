@model TravelTripProje.Models.Sınıflar.Otel
@{
    ViewBag.Title = "YeniOtel";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Yeni Otel Ekleme</h2>
<br />
<form class="form-group" method="post">
    @Html.LabelFor(x => x.Ad)
    @Html.TextBoxFor(x => x.Ad, new { @class = "form-control" })
    <br />
    @Html.LabelFor(x => x.Yatak_Sayisi)
    @Html.TextBoxFor(x => x.Yatak_Sayisi, new { @class = "form-control" })
    <br />
    @Html.LabelFor(x => x.Banyo_Sayisi)
    @Html.TextBoxFor(x => x.Banyo_Sayisi, new { @class = "form-control" })
    <br />
    @Html.LabelFor(x => x.Kisi_Basi_Fiyat)
    @Html.TextBoxFor(x => x.Kisi_Basi_Fiyat, new { @class = "form-control" })
    <br />
    @Html.LabelFor(x => x.OtelImage)
    @Html.TextBoxFor(x => x.OtelImage, new { @class = "form-control" })
    <br />
    @Html.LabelFor(x => x.Adres)
    @Html.TextBoxFor(x => x.Adres, new { @class = "form-control" })
    <br />
    @Html.LabelFor(x => x.Kampanya_ID)
    @Html.TextBoxFor(x => x.Kampanya_ID, new { @class = "form-control" })
    <br />
    @Html.LabelFor(x => x.OtelKategori_ID)
    @Html.TextBoxFor(x => x.OtelKategori_ID, new { @class = "form-control" })
    <br />
    <button class="btn btn-primary">Otel Ekle</button>
</form>

