@using TravelTripProje.Models.Sınıflar;
@model List<Tur>
<section class="ftco-section ftco-no-pt">
    <div class="container">
        <div class="row justify-content-center pb-4">
            <div class="col-md-12 heading-section text-center ftco-animate">
                <h2 class="mb-4">Turlar</h2>
            </div>
        </div>
        <div class="row d-flex">
            @foreach (var x in Model)
            {
                if (Model.IndexOf(x) == 0) // İlk tur için büyük alan (col-md-12)
                {
                    <div class="col-md-12 d-flex ftco-animate">
                        <div class="blog-entry justify-content-end">
                            <a href="/Tur/TurDetay/@x.Tur_ID" class="block-20" style="background-image: url('@x.TurImage'); width:1350px;height:350px;">
                            </a>
                            <div class="text mt-3 float-right d-block">
                                <div class="d-flex align-items-center mb-4 topp">
                                    <div class="one">
                                        @*<span class="day">1</span>*@
                                    </div>
                                    <div class="two">
                                        <span class="yr" style="font-size: 20px; margin-left: -60px;">Kişi Başı: @x.Kisi_Basi_Fiyat</span>
                                        @*<span class="mos">3</span>*@
                                    </div>
                                </div>
                                <h3 class="heading"><a href="/Tur/TurDetay/@x.Tur_ID">@x.Ad</a></h3>
                                <p><strong>Rota:</strong> @x.Rota</p>
                                <p><strong>Kişi Başı Fiyat:</strong> @x.Kisi_Basi_Fiyat</p>
                            </div>
                        </div>
                    </div>
                }
                else // Diğer turlar için küçük alan (col-md-6)
                {
                    <div class="col-md-6 d-flex ftco-animate">
                        <div class="blog-entry justify-content-end">
                            <a href="/Tur/TurDetay/@x.Tur_ID" class="block-20" style="background-image: url('@x.TurImage');width:650px;height:350px;">
                            </a>
                            <div class="text mt-3 float-right d-block">
                                <div class="d-flex align-items-center mb-4 topp">
                                    <div class="one">
                                        @*<span class="day">1</span>*@
                                    </div>
                                    <div class="two">
                                        <span class="yr" style="font-size: 20px; margin-left: -60px;">Kişi Başı: @x.Kisi_Basi_Fiyat</span>
                                        @*<span class="mos">3</span>*@
                                    </div>
                                </div>
                                <h3 class="heading"><a href="/Tur/TurDetay/@x.Tur_ID">@x.Ad</a></h3>
                                <p><strong>Rota:</strong> @x.Rota</p>
                                <p><strong>Kişi Başı Fiyat:</strong> @x.Kisi_Basi_Fiyat</p>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

