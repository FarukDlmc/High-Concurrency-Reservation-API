
@{
    ViewBag.Title = "iletisim";
    Layout = "~/Views/Shared/_LayoutSon.cshtml";
}

<!DOCTYPE html>
<html lang="en">
<body>

    <section class="hero-wrap hero-wrap-2 js-fullheight" style="background-image:url('@Url.Content("~/template1/images/tel.jpg")');" data-stellar-background-ratio="0.5">
        <div class="overlay"></div>
        <div class="container">
            <div class="row no-gutters slider-text js-fullheight align-items-end justify-content-center">
                <div class="col-md-9 ftco-animate pb-5 text-center">
                    <h1 class="mb-3 bread">İletişim</h1>
                    <p class="breadcrumbs"><span class="mr-2"><a href="/Default/Index">Ana Sayfa <i class="ion-ios-arrow-forward"></i></a></span> <span>İletişim <i class="ion-ios-arrow-forward"></i></span></p>
                </div>
            </div>
        </div>
    </section>

    <section class="ftco-section ftco-no-pb contact-section">
        <div class="container">
            <div class="row d-flex contact-info">
                <div class="col-md-3 d-flex">
                    <div class="align-self-stretch box p-4 text-center">
                        <div class="icon d-flex align-items-center justify-content-center">
                            <span class="icon-map-signs"></span>
                        </div>
                        <h3 class="mb-2">Adres</h3>
                        <p>Beştepe, Cumhurbaşkanlığı Blv, 06560 Yenimahalle/Ankara</p>
                    </div>
                </div>
                <div class="col-md-3 d-flex">
                    <div class="align-self-stretch box p-4 text-center">
                        <div class="icon d-flex align-items-center justify-content-center">
                            <span class="icon-phone2"></span>
                        </div>
                        <h3 class="mb-2">İletişim Numarası</h3>
                        <p><a href="tel://1234567920">+ 1235 2355 98</a></p>
                    </div>
                </div>
                <div class="col-md-3 d-flex">
                    <div class="align-self-stretch box p-4 text-center">
                        <div class="icon d-flex align-items-center justify-content-center">
                            <span class="icon-paper-plane"></span>
                        </div>
                        <h3 class="mb-2">Email</h3>
                        <p><a href="mailto:info@yoursite.com">info@yoursite.com</a></p>
                    </div>
                </div>
                <div class="col-md-3 d-flex">
                    <div class="align-self-stretch box p-4 text-center">
                        <div class="icon d-flex align-items-center justify-content-center">
                            <span class="icon-globe"></span>
                        </div>
                        <h3 class="mb-2">Web Sitesi</h3>
                        <p><a href="#">yoursite.com</a></p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="ftco-section contact-section">
        <div class="container">
            <div class="row block-9">
                <div class="col-md-6 order-md-last d-flex">
                    <form action="#" class="bg-light p-5 contact-form">
                        <div class="form-group">
                            <input type="text" class="form-control" placeholder="Ad Soyad">
                        </div>
                        <div class="form-group">
                            <input type="email" class="form-control" placeholder="Email">
                        </div>
                        <div class="form-group">
                            <input type="text" class="form-control" placeholder="Konu">
                        </div>
                        <div class="form-group">
                            <textarea name="" id="" cols="30" rows="7" class="form-control" placeholder="Mesaj"></textarea>
                        </div>
                        <div class="form-group">
                            <input type="submit" value="Gönder" class="btn btn-primary py-3 px-5">
                        </div>
                    </form>

                </div>

                <div class="col-md-6 d-flex" width="1200px" height="250px" style="border:0" allowfullscreen="" loading="lazy">

                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3796.4508212680707!2d32.79650157651282!3d39.930891385065046!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14d34f8f6ccdb7df%3A0xa9ee717727a3fee!2zVC5DIEN1bWh1cmJhxZ9rYW5sxLHEn8SxIEvDvGxsaXllc2k!5e1!3m2!1str!2str!4v1733904176046!5m2!1str!2str"
                            width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                </div>

            </div>
        </div>
    </section>
    <!-- loader -->
    <div id="ftco-loader" class="show fullscreen"><svg class="circular" width="48px" height="48px"><circle class="path-bg" cx="24" cy="24" r="22" fill="none" stroke-width="4" stroke="#eeeeee" /><circle class="path" cx="24" cy="24" r="22" fill="none" stroke-width="4" stroke-miterlimit="10" stroke="#F96D00" /></svg></div>


    <script src="~/template1/js/jquery.min.js"></script>
    <script src="~/template1/js/jquery-migrate-3.0.1.min.js"></script>
    <script src="~/template1/js/popper.min.js"></script>
    <script src="~/template1/js/bootstrap.min.js"></script>
    <script src="~/template1/js/jquery.easing.1.3.js"></script>
    <script src="~/template1/js/jquery.waypoints.min.js"></script>
    <script src="~/template1/js/jquery.stellar.min.js"></script>
    <script src="~/template1/js/owl.carousel.min.js"></script>
    <script src="~/template1/js/jquery.magnific-popup.min.js"></script>
    <script src="~/template1/js/aos.js"></script>
    <script src="~/template1/js/jquery.animateNumber.min.js"></script>
    <script src="~/template1/js/bootstrap-datepicker.js"></script>
    <script src="~/template1/js/scrollax.min.js"></script>
    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyBVWaKrjvy3MaE7SQ74_uJiULgl1JY0H2s&sensor=false"></script>
    <script src="~/template1/js/google-map.js"></script>
    <script src="~/template1/js/main.js"></script>

</body>
</html>


